{
  "name": "Expense Tracker",
  "short_name": "Expenses",
  "description": "Capture daily spending quickly, offline-first.",
  "id": "./",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
